# ============================================================
# 叙光 (NarrLight) - 环境变量配置
# 复制此文件为 .env.local 并填入实际值
# ============================================================

# --- Supabase 连接配置 ---
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- AI Provider 配置 ---
# mock: use local placeholder data. real: call DeepSeek / Supabase Edge Functions.
AI_GENERATION_MODE=mock
DEEPSEEK_API_KEY=your-deepseek-api-key
GLM_API_KEY=your-glm-api-key
GLM_IMAGE_MODEL=cogview-3-plus
OPENAI_API_KEY=your-openai-api-key
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_PROXY_URL=http://127.0.0.1:7890
ARK_API_KEY=your-volcengine-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_PROXY_URL=http://127.0.0.1:7890
SEEDREAM_IMAGE_MODEL=your-seedream-model-or-endpoint-id
# Backward-compatible alias if the team calls this capability SeedDance in UI/docs.
SEEDDANCE_IMAGE_MODEL=your-seedream-model-or-endpoint-id

# --- 应用配置（可选） ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
